{
  "manifest_version": 1,
  "module": "eev",
  "description": "Електронний розширювальний клапан — PI регулятор перегріву",

  "inputs": {
    "equipment.evap_temp": {
      "source_module": "equipment",
      "type": "float",
      "optional": false,
      "description": "Температура на виході випарника (°C)"
    },
    "equipment.compressor": {
      "source_module": "equipment",
      "type": "bool",
      "optional": false,
      "description": "Фактичний стан компресора"
    },
    "equipment.suction_bar": {
      "source_module": "equipment",
      "type": "float",
      "optional": false,
      "description": "Тиск всмоктування (bar)"
    },
    "equipment.has_suction_p": {
      "source_module": "equipment",
      "type": "bool",
      "optional": true,
      "description": "Наявність датчика тиску всмоктування"
    },
    "equipment.sensor2_ok": {
      "source_module": "equipment",
      "type": "bool",
      "optional": false,
      "description": "Справність датчика випарника"
    },
    "defrost.active": {
      "source_module": "defrost",
      "type": "bool",
      "optional": true,
      "description": "Прапорець активного відтаювання"
    },
    "equipment.refrigerant": {
      "source_module": "equipment",
      "type": "int",
      "optional": true,
      "description": "Індекс типу холодоагенту (з saturation.h)"
    },
    "thermostat.temperature": {
      "source_module": "thermostat",
      "type": "float",
      "optional": true,
      "description": "Температура камери (для Smooth Lines)"
    },
    "thermostat.effective_setpoint": {
      "source_module": "thermostat",
      "type": "float",
      "optional": true,
      "description": "Ефективний setpoint (для Smooth Lines)"
    }
  },

  "features": {
    "superheat_control": {
      "description": "PI регулювання перегріву з EEV",
      "requires_roles": ["eev_z1"],
      "controls_settings": [
        "eev.sh_target", "eev.kp", "eev.ki",
        "eev.startup_pos", "eev.startup_wait",
        "eev.min_pos", "eev.max_pos", "eev.safe_pos",
        "eev.low_sh_limit", "eev.mop_pressure", "eev.deadband"
      ]
    }
  },

  "state": {
    "eev.superheat": {
      "type": "float",
      "access": "read",
      "unit": "K",
      "description": "Поточний перегрів (T_випарника - T_насичення)"
    },
    "eev.t_sat": {
      "type": "float",
      "access": "read",
      "unit": "°C",
      "description": "Температура насичення з тиску всмоктування"
    },
    "eev.valve_pos": {
      "type": "float",
      "access": "read",
      "unit": "%",
      "description": "Позиція клапана 0-100%"
    },
    "eev.state": {
      "type": "string",
      "access": "read",
      "description": "Стан: idle/startup/running/low_sh/defrost/fault"
    },
    "eev.pi_output": {
      "type": "float",
      "access": "read",
      "description": "Вихід PI регулятора (кроків/цикл)"
    },
    "eev.req.valve_pos": {
      "type": "float",
      "access": "read",
      "unit": "%",
      "description": "Запитана позиція клапана"
    },

    "eev.sh_target": {
      "type": "float",
      "access": "readwrite",
      "min": 2.0, "max": 25.0, "step": 0.5,
      "default": 8.0,
      "persist": true,
      "unit": "K",
      "description": "Уставка перегріву"
    },
    "eev.kp": {
      "type": "float",
      "access": "readwrite",
      "min": 0.1, "max": 20.0, "step": 0.1,
      "default": 3.0,
      "persist": true,
      "description": "Пропорційний коеф. PI"
    },
    "eev.ki": {
      "type": "float",
      "access": "readwrite",
      "min": 0.01, "max": 5.0, "step": 0.01,
      "default": 0.5,
      "persist": true,
      "description": "Інтегральний коеф. PI"
    },
    "eev.startup_pos": {
      "type": "float",
      "access": "readwrite",
      "min": 10.0, "max": 80.0, "step": 1.0,
      "default": 50.0,
      "persist": true,
      "unit": "%",
      "description": "Позиція клапана при старті компресора"
    },
    "eev.startup_wait": {
      "type": "int",
      "access": "readwrite",
      "min": 30, "max": 600, "step": 10,
      "default": 120,
      "persist": true,
      "unit": "s",
      "description": "Затримка PI після старту компресора"
    },
    "eev.min_pos": {
      "type": "float",
      "access": "readwrite",
      "min": 0.0, "max": 30.0, "step": 1.0,
      "default": 5.0,
      "persist": true,
      "unit": "%",
      "description": "Мін. позиція клапана при регулюванні"
    },
    "eev.max_pos": {
      "type": "float",
      "access": "readwrite",
      "min": 50.0, "max": 100.0, "step": 1.0,
      "default": 95.0,
      "persist": true,
      "unit": "%",
      "description": "Макс. позиція клапана при регулюванні"
    },
    "eev.safe_pos": {
      "type": "float",
      "access": "readwrite",
      "min": 10.0, "max": 60.0, "step": 1.0,
      "default": 20.0,
      "persist": true,
      "unit": "%",
      "description": "Безпечна позиція при відмові датчика (10-20% рекомендовано)"
    },
    "eev.low_sh_limit": {
      "type": "float",
      "access": "readwrite",
      "min": 0.0, "max": 5.0, "step": 0.5,
      "default": 2.0,
      "persist": true,
      "unit": "K",
      "description": "Поріг захисту від низького перегріву"
    },
    "eev.mop_pressure": {
      "type": "float",
      "access": "readwrite",
      "min": 0.0, "max": 30.0, "step": 0.5,
      "default": 0.0,
      "persist": true,
      "unit": "bar",
      "description": "Макс. робочий тиск (0=вимкнено)"
    },
    "eev.lop_pressure": {
      "type": "float",
      "access": "readwrite",
      "min": 0.0, "max": 15.0, "step": 0.1,
      "default": 0.0,
      "persist": true,
      "unit": "bar",
      "description": "Мін. робочий тиск (0=вимкнено)"
    },
    "eev.deadband": {
      "type": "float",
      "access": "readwrite",
      "min": 0.0, "max": 5.0, "step": 0.1,
      "default": 0.5,
      "persist": true,
      "unit": "K",
      "description": "Зона нечутливості PI (антихантінг)"
    },
    "eev.pi_interval": {
      "type": "int",
      "access": "readwrite",
      "min": 1, "max": 30, "step": 1,
      "default": 3,
      "persist": true,
      "unit": "s",
      "description": "Інтервал розрахунку PI"
    },
    "eev.exercise_interval": {
      "type": "int",
      "access": "readwrite",
      "min": 0, "max": 168, "step": 1,
      "default": 24,
      "persist": true,
      "unit": "год",
      "description": "Інтервал розблокування клапана (0=вимкнено)"
    },
    "eev.smooth_lines": {
      "type": "bool",
      "access": "readwrite",
      "default": false,
      "persist": true,
      "description": "Smooth Lines — динамічний SH setpoint по T камери"
    },
    "eev.smooth_max_offset": {
      "type": "float",
      "unit": "K",
      "access": "readwrite",
      "min": 0, "max": 50, "step": 1,
      "default": 15,
      "persist": true,
      "description": "Макс. зміщення SH (Smooth Lines)"
    },
    "eev.smooth_plt": {
      "type": "float",
      "unit": "°C",
      "access": "readwrite",
      "min": 0.5, "max": 10, "step": 0.5,
      "default": 2.0,
      "persist": true,
      "description": "Offset нижче setpoint для зупинки (Smooth Lines)"
    },
    "eev.valve_type": {
      "type": "int",
      "access": "readwrite",
      "persist": true,
      "default": 0,
      "options": [
        {"value": 0, "label": "Не підключено"},
        {"value": 1, "label": "E2V stepper (PCF8574 → H-bridge)"},
        {"value": 2, "label": "E2V analog (DAC 0-10V → EVD Mini)"},
        {"value": 3, "label": "AKV solenoid (PWM)"},
        {"value": 4, "label": "E2V stepper (GPIO → TMC2209)"}
      ],
      "description": "Тип клапана EEV"
    },
    "eev.max_steps": {
      "type": "int",
      "access": "readwrite",
      "persist": true,
      "min": 100, "max": 6400, "step": 10,
      "default": 480,
      "description": "Макс. кроків клапана (E2V=480, ETS=600, EX=750)"
    }
  },

  "mqtt": {
    "publish": [
      "eev.superheat", "eev.t_sat", "eev.valve_pos", "eev.state",
      "eev.pi_output", "eev.sh_target"
    ],
    "subscribe": [
      "eev.sh_target", "eev.kp", "eev.ki",
      "eev.startup_pos", "eev.startup_wait",
      "eev.min_pos", "eev.max_pos", "eev.safe_pos",
      "eev.low_sh_limit", "eev.mop_pressure", "eev.lop_pressure", "eev.deadband",
      "eev.pi_interval", "eev.exercise_interval",
      "eev.smooth_lines", "eev.smooth_max_offset", "eev.smooth_plt"
    ]
  },

  "ui": {
    "page": "EEV",
    "icon": "thermometer",
    "cards": [
      {
        "title": "Стан",
        "icon": "thermometer",
        "icon_color": "blue",
        "subtitle": "Перегрів, клапан, стан",
        "summary_keys": ["eev.superheat", "eev.valve_pos"],
        "wide": true,
        "widgets": [
          {"key": "eev.superheat", "widget": "gauge", "label": "Перегрів", "unit": "K", "min": -5, "max": 30},
          {"key": "eev.t_sat", "widget": "value", "label": "T насичення", "unit": "°C"},
          {"key": "eev.valve_pos", "widget": "gauge", "label": "Клапан", "unit": "%", "min": 0, "max": 100},
          {"key": "eev.state", "widget": "status_text", "label": "Стан"}
        ]
      },
      {
        "title": "Основне",
        "icon": "sliders",
        "icon_color": "green",
        "subtitle": "Тип клапана, цільовий перегрів",
        "summary_keys": ["eev.sh_target", "eev.valve_type"],
        "widgets": [
          {"key": "eev.valve_type", "widget": "select", "label": "Тип клапана"},
          {"key": "eev.max_steps", "widget": "number_input", "label": "Макс. кроків", "visible_when": {"key": "eev.valve_type", "neq": 0}},
          {"key": "eev.sh_target", "widget": "number_input", "label": "Цільовий перегрів", "unit": "K"}
        ]
      },
      {
        "title": "Захист",
        "icon": "shield",
        "icon_color": "orange",
        "subtitle": "MOP, LOP, мін. перегрів",
        "group": "service",
        "collapsible": true,
        "feature": "superheat_control",
        "widgets": [
          {"key": "eev.low_sh_limit", "widget": "number_input", "label": "Мін. перегрів", "unit": "K"},
          {"key": "eev.mop_pressure", "widget": "number_input", "label": "MOP тиск", "unit": "bar"},
          {"key": "eev.lop_pressure", "widget": "number_input", "label": "LOP тиск", "unit": "bar"},
          {"key": "eev.exercise_interval", "widget": "number_input", "label": "Розблокування клапана", "unit": "год"}
        ]
      },
      {
        "title": "Налаштування PI",
        "icon": "settings",
        "icon_color": "gray",
        "subtitle": "Kp, Ki, інтервал, позиції",
        "group": "expert",
        "collapsible": true,
        "feature": "superheat_control",
        "widgets": [
          {"key": "eev.kp", "widget": "number_input", "label": "Kp (пропорційна)"},
          {"key": "eev.ki", "widget": "number_input", "label": "Ki (інтегральна)"},
          {"key": "eev.deadband", "widget": "number_input", "label": "Зона нечутливості", "unit": "K"},
          {"key": "eev.pi_interval", "widget": "number_input", "label": "Інтервал PI", "unit": "с"},
          {"key": "eev.startup_pos", "widget": "number_input", "label": "Стартова позиція", "unit": "%"},
          {"key": "eev.startup_wait", "widget": "number_input", "label": "Затримка старту", "unit": "с"},
          {"key": "eev.min_pos", "widget": "number_input", "label": "Мін. позиція", "unit": "%"},
          {"key": "eev.max_pos", "widget": "number_input", "label": "Макс. позиція", "unit": "%"},
          {"key": "eev.safe_pos", "widget": "number_input", "label": "Безпечна позиція", "unit": "%"},
          {"key": "eev.pi_output", "widget": "value", "label": "PI вихід (діагностика)"}
        ]
      },
      {
        "title": "Smooth Lines",
        "icon": "trending-down",
        "icon_color": "green",
        "subtitle": "Динамічний SH setpoint по T камери",
        "group": "expert",
        "collapsible": true,
        "feature": "superheat_control",
        "widgets": [
          {"key": "eev.smooth_lines", "widget": "toggle", "label": "Smooth Lines"},
          {"key": "eev.smooth_max_offset", "widget": "number_input", "label": "Макс. зміщення SH",
           "visible_when": {"key": "eev.smooth_lines", "eq": true}},
          {"key": "eev.smooth_plt", "widget": "number_input", "label": "PLt (offset нижче SP)",
           "visible_when": {"key": "eev.smooth_lines", "eq": true}}
        ]
      }
    ]
  }
}
