{
  "manifest_version": 1,
  "module": "equipment",
  "description": "Equipment Manager — HAL abstraction layer with arbitration",

  "requires": [
    {"role": "air_temp",       "type": "sensor",   "driver": ["ds18b20", "ntc"], "label": "Темп. камери"},
    {"role": "compressor",     "type": "actuator", "driver": ["relay", "pcf8574_relay"], "label": "Компресор"},
    {"role": "evap_temp",      "type": "sensor",   "driver": ["ds18b20", "ntc"], "label": "Темп. випарника",      "optional": true},
    {"role": "condenser_temp", "type": "sensor",   "driver": ["ds18b20", "ntc"], "label": "Темп. конденсатора",   "optional": true},
    {"role": "defrost_relay",  "type": "actuator", "driver": ["relay", "pcf8574_relay"], "label": "Реле відтайки",        "optional": true},
    {"role": "evap_fan",       "type": "actuator", "driver": ["relay", "pcf8574_relay"], "label": "Вент. випарника",      "optional": true},
    {"role": "cond_fan",       "type": "actuator", "driver": ["relay", "pcf8574_relay"], "label": "Вент. конденсатора",   "optional": true},
    {"role": "door_contact",   "type": "sensor",   "driver": ["digital_input", "pcf8574_input"], "label": "Контакт дверей",       "optional": true},
    {"role": "night_input",    "type": "sensor",   "driver": ["digital_input", "pcf8574_input"], "label": "Вхід нічного режиму",  "optional": true},
    {"role": "light",          "type": "actuator", "driver": ["relay", "pcf8574_relay"], "label": "Освітлення камери",    "optional": true},
    {"role": "suction_p",     "type": "sensor",   "driver": ["pressure_adc"],          "label": "Тиск всмоктування",    "optional": true},
    {"role": "discharge_p",   "type": "sensor",   "driver": ["pressure_adc"],          "label": "Тиск нагнітання",      "optional": true},
    {"role": "eev",           "type": "actuator", "driver": ["eev_analog", "eev_stepper", "akv_pulse"], "label": "Клапан EEV", "optional": true},

    {"role": "evap_temp_z1",     "type": "sensor",   "driver": ["ds18b20", "ntc"],          "label": "Темп. випарника зона 1",     "optional": true},
    {"role": "evap_temp_z2",     "type": "sensor",   "driver": ["ds18b20", "ntc"],          "label": "Темп. випарника зона 2",     "optional": true},
    {"role": "suction_p_z1",     "type": "sensor",   "driver": ["pressure_adc"],            "label": "Тиск всмоктування зона 1",   "optional": true},
    {"role": "suction_p_z2",     "type": "sensor",   "driver": ["pressure_adc"],            "label": "Тиск всмоктування зона 2",   "optional": true},
    {"role": "defrost_relay_z1", "type": "actuator", "driver": ["relay", "pcf8574_relay"],  "label": "Реле відтайки зона 1",       "optional": true},
    {"role": "defrost_relay_z2", "type": "actuator", "driver": ["relay", "pcf8574_relay"],  "label": "Реле відтайки зона 2",       "optional": true},
    {"role": "evap_fan_z1",      "type": "actuator", "driver": ["relay", "pcf8574_relay"],  "label": "Вент. випарника зона 1",     "optional": true},
    {"role": "evap_fan_z2",      "type": "actuator", "driver": ["relay", "pcf8574_relay"],  "label": "Вент. випарника зона 2",     "optional": true},
    {"role": "eev_z1",           "type": "actuator", "driver": ["eev_analog", "eev_stepper", "akv_pulse"], "label": "Клапан EEV зона 1", "optional": true},
    {"role": "eev_z2",           "type": "actuator", "driver": ["eev_analog", "eev_stepper", "akv_pulse"], "label": "Клапан EEV зона 2", "optional": true}
  ],

  "state": {
    "equipment.air_temp":    {"type": "float", "access": "read", "unit": "°C", "description": "Температура камери"},
    "equipment.evap_temp":   {"type": "float", "access": "read", "unit": "°C", "description": "Температура випарника"},
    "equipment.sensor1_ok":  {"type": "bool",  "access": "read", "description": "Датчик камери справний"},
    "equipment.sensor2_ok":  {"type": "bool",  "access": "read", "description": "Датчик випарника справний"},
    "equipment.compressor":  {"type": "bool",  "access": "read", "description": "Фактичний стан компресора"},
    "equipment.defrost_relay": {"type": "bool", "access": "read", "description": "Фактичний стан реле відтайки"},
    "equipment.evap_fan":    {"type": "bool",  "access": "read", "description": "Фактичний стан вент. випарника"},
    "equipment.cond_fan":    {"type": "bool",  "access": "read", "description": "Фактичний стан вент. конденсатора"},
    "equipment.cond_temp":   {"type": "float", "access": "read", "unit": "°C", "description": "Температура конденсатора"},
    "equipment.door_open":        {"type": "bool",  "access": "read", "description": "Стан дверей"},
    "equipment.night_input":      {"type": "bool",  "access": "read", "description": "Дискретний вхід нічного режиму"},
    "equipment.has_defrost_relay": {"type": "bool", "access": "read", "description": "Реле відтайки доступне"},
    "equipment.has_cond_fan":     {"type": "bool",  "access": "read", "description": "Вент. конденсатора доступний"},
    "equipment.has_door_contact": {"type": "bool",  "access": "read", "description": "Контакт дверей доступний"},
    "equipment.has_evap_temp":    {"type": "bool",  "access": "read", "description": "Датчик випарника доступний"},
    "equipment.has_cond_temp":    {"type": "bool",  "access": "read", "description": "Датчик конденсатора доступний"},
    "equipment.has_night_input":  {"type": "bool",  "access": "read", "description": "Вхід нічного режиму доступний"},
    "equipment.light":            {"type": "bool",  "access": "read", "description": "Фактичний стан освітлення"},
    "equipment.has_light":        {"type": "bool",  "access": "read", "description": "Реле освітлення доступне"},
    "equipment.has_ntc_driver":   {"type": "bool",  "access": "read", "description": "Використовується NTC драйвер"},
    "equipment.has_suction_p":   {"type": "bool",  "access": "read", "description": "Датчик тиску всмоктування доступний"},
    "equipment.has_discharge_p": {"type": "bool",  "access": "read", "description": "Датчик тиску нагнітання доступний"},
    "equipment.has_eev":         {"type": "bool",  "access": "read", "description": "EEV клапан доступний"},
    "equipment.suction_bar":     {"type": "float", "access": "read", "unit": "bar", "description": "Тиск всмоктування"},
    "equipment.discharge_bar":   {"type": "float", "access": "read", "unit": "bar", "description": "Тиск нагнітання"},
    "equipment.refrigerant":     {"type": "int",   "access": "readwrite", "persist": true,
                                  "min": 0, "max": 22, "step": 1, "default": 0,
                                  "description": "Тип холодоагенту (0=R134a, 1=R404A, ...)"},
    "equipment.has_ds18b20_driver": {"type": "bool", "access": "read", "description": "Використовується DS18B20 драйвер"},

    "equipment.evap_temp_z1":         {"type": "float", "unit": "°C", "access": "read", "description": "Темп. випарника зона 1"},
    "equipment.evap_temp_z2":         {"type": "float", "unit": "°C", "access": "read", "description": "Темп. випарника зона 2"},
    "equipment.sensor2_z1_ok":        {"type": "bool", "access": "read", "description": "Датчик випарника зона 1 справний"},
    "equipment.sensor2_z2_ok":        {"type": "bool", "access": "read", "description": "Датчик випарника зона 2 справний"},
    "equipment.suction_bar_z1":       {"type": "float", "unit": "bar", "access": "read", "description": "Тиск всмоктування зона 1"},
    "equipment.suction_bar_z2":       {"type": "float", "unit": "bar", "access": "read", "description": "Тиск всмоктування зона 2"},
    "equipment.has_suction_p_z1":     {"type": "bool", "access": "read", "description": "Датчик тиску зона 1 доступний"},
    "equipment.has_suction_p_z2":     {"type": "bool", "access": "read", "description": "Датчик тиску зона 2 доступний"},
    "equipment.has_defrost_relay_z1": {"type": "bool", "access": "read", "description": "Реле відтайки зона 1 доступне"},
    "equipment.has_defrost_relay_z2": {"type": "bool", "access": "read", "description": "Реле відтайки зона 2 доступне"},

    "equipment.filter_coeff":    {"type": "int", "access": "readwrite", "persist": true,
                                  "min": 0, "max": 10, "step": 1, "default": 4,
                                  "description": "Цифровий фільтр"},

    "equipment.ntc_beta":        {"type": "int",   "access": "readwrite", "persist": true,
                                  "min": 2000, "max": 5000, "step": 1, "default": 3950,
                                  "description": "B-коефіцієнт NTC"},
    "equipment.ntc_r_series":    {"type": "int",   "access": "readwrite", "persist": true,
                                  "min": 1000, "max": 100000, "step": 100, "default": 10000,
                                  "unit": "Ом", "description": "Послідовний резистор NTC"},
    "equipment.ntc_r_nominal":   {"type": "int",   "access": "readwrite", "persist": true,
                                  "min": 1000, "max": 100000, "step": 100, "default": 10000,
                                  "unit": "Ом", "description": "Номінальний опір NTC (25°C)"},

    "equipment.ds18b20_offset":   {"type": "float", "access": "readwrite", "persist": true,
                                   "min": -5.0, "max": 5.0, "step": 0.1, "default": 0.0,
                                   "unit": "°C", "description": "Корекція показань DS18B20"}
  },


  "mqtt": {
    "publish": [
      "equipment.air_temp",
      "equipment.evap_temp",
      "equipment.cond_temp",
      "equipment.compressor",
      "equipment.defrost_relay",
      "equipment.sensor1_ok"
    ],
    "subscribe": [
      "equipment.ntc_beta",
      "equipment.ntc_r_series",
      "equipment.ntc_r_nominal",
      "equipment.ds18b20_offset",
      "equipment.filter_coeff"
    ]
  },

  "display": {
    "main_value": {
      "key": "equipment.air_temp",
      "format": "%.1f°C"
    }
  }
}
