    {"hardware": "adc_3",  "driver": "pressure_adc", "role": "discharge_p",  "module": "equipment", "params": {"p_range": 60.0}},

    {"hardware": "dac_1",  "driver": "eev_analog", "role": "eev_z1", "module": "equipment"},
    {"hardware": "dac_2",  "driver": "eev_analog", "role": "eev_z2", "module": "equipment"},

    {"hardware": "din_1",  "driver": "pcf8574_input", "role": "door_contact", "module": "equipment"},
    {"hardware": "din_2",  "driver": "pcf8574_input", "role": "night_input",  "module": "equipment"}
