{
  "manifest_version": 1,
  "board": "kc868_a6",
  "version": "1.1.0",
  "description": "KC868-A6: 6 relay, 6 DI, 2 DAC, 4 ADC, I2C, RS-485",
  "i2c_buses": [
    {"id": "i2c_0", "sda": 4, "scl": 15, "freq_hz": 100000, "label": "I2C"}
  ],
  "i2c_expanders": [
    {"id": "relay_exp", "bus": "i2c_0", "chip": "pcf8574", "address": "0x24", "pins": 8, "label": "Relay"},
    {"id": "input_exp", "bus": "i2c_0", "chip": "pcf8574", "address": "0x22", "pins": 8, "label": "Input"}
  ],
  "expander_outputs": [
    {"id": "relay_1", "expander": "relay_exp", "pin": 0, "active_high": false, "label": "R1"},
    {"id": "relay_2", "expander": "relay_exp", "pin": 1, "active_high": false, "label": "R2"},
    {"id": "relay_3", "expander": "relay_exp", "pin": 2, "active_high": false, "label": "R3"},
    {"id": "relay_4", "expander": "relay_exp", "pin": 3, "active_high": false, "label": "R4"},
    {"id": "relay_5", "expander": "relay_exp", "pin": 4, "active_high": false, "label": "R5"},
    {"id": "relay_6", "expander": "relay_exp", "pin": 5, "active_high": false, "label": "R6"},
    {"id": "relay_7", "expander": "relay_exp", "pin": 6, "active_high": false, "label": "R7"},
    {"id": "relay_8", "expander": "relay_exp", "pin": 7, "active_high": false, "label": "R8"},
    {"id": "eev_step_1", "expander": "input_exp", "pin": 2, "active_high": true, "label": "STEP1"},
    {"id": "eev_dir_1", "expander": "input_exp", "pin": 3, "active_high": true, "label": "DIR1"},
    {"id": "eev_step_2", "expander": "input_exp", "pin": 4, "active_high": true, "label": "STEP2"},
    {"id": "eev_dir_2", "expander": "input_exp", "pin": 5, "active_high": true, "label": "DIR2"}
  ],
  "expander_inputs": [
    {"id": "din_1", "expander": "input_exp", "pin": 0, "invert": true, "label": "DI1"},
    {"id": "din_2", "expander": "input_exp", "pin": 1, "invert": true, "label": "DI2"},
    {"id": "din_3", "expander": "input_exp", "pin": 2, "invert": true, "label": "DI3"},
    {"id": "din_4", "expander": "input_exp", "pin": 3, "invert": true, "label": "DI4"},
    {"id": "din_5", "expander": "input_exp", "pin": 4, "invert": true, "label": "DI5"},
    {"id": "din_6", "expander": "input_exp", "pin": 5, "invert": true, "label": "DI6"}
  ],
  "onewire_buses": [
    {"id": "ow_1", "gpio": 32, "label": "OW1"},
    {"id": "ow_2", "gpio": 33, "label": "OW2"}
  ],
  "adc_channels": [
    {"id": "adc_1", "gpio": 36, "atten": 3, "label": "ADC1"},
    {"id": "adc_2", "gpio": 39, "atten": 3, "label": "ADC2"},
    {"id": "adc_3", "gpio": 34, "atten": 3, "label": "ADC3"},
    {"id": "adc_4", "gpio": 35, "atten": 3, "label": "ADC4"}
  ],
  "dac_channels": [
    {"id": "dac_1", "gpio": 25, "label": "DAC1"},
    {"id": "dac_2", "gpio": 26, "label": "DAC2"}
  ],
  "uart_buses": [
    {"id": "rs485_1", "tx_gpio": 27, "rx_gpio": 14, "label": "RS485"},
    {"id": "rs485_2", "tx_gpio": 17, "rx_gpio": 16, "label": "RS485-EXP"}
  ]
}
